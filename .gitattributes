# Normalize line endings
* text=auto eol=lf

# Force LF for these file types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf

# Binary files — no conversion
*.jpg  binary
*.jpeg binary
*.png  binary
*.ico  binary
*.woff binary
*.woff2 binary
